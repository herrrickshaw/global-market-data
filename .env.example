# Copy this file to `.env` (which is gitignored) and fill in your real values.
#   cp .env.example .env      then edit .env in your editor
# The `.env` file is never committed — keep your real password only there.

# screener.in login (unlocks India company fundamentals — see SCREENER_ACCESS.md)
SCREENER_EMAIL=you@example.com
SCREENER_PASSWORD=your-screener-password

# optional: email sending for the daily mailer (see send_mailer.py)
# GMAIL_USER=you@gmail.com
# GMAIL_APP_PASSWORD=your-16-char-app-password
# MAIL_TO=you@gmail.com
