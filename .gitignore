# runtime artifacts (regenerable) — keep the repo to code + committed seeds
__pycache__/
*.pyc
*.log
*.tmp
brief_today.html
india_mailer.html
mailer_tomorrow.html

# scan / report outputs (regenerated by the pipeline)
combined_report_results/
indian_full_scan/
us_full_scan/
*_results/
*_scan/
global_highlights.xlsx
market_performance_5y.xlsx

# local bulk caches & embedded third-party repos (NOT shipped)
market_cache/
nse_cache/
bhavcopy_cache/
claude-lmstudio-router/
cache_seed/*.tmp
launchd_out.log
launchd_err.log

results/
results_top150_global.csv
full_report.html

# machine-specific data index / store state (regenerated locally by datalink)
cache_seed/data_manifest.json
cache_seed/.store_state.json

# derived serving views + CDC delta logs (rebuilt daily by serving_layer)
cache_seed/serving/
cache_seed/cdc/

# secrets — never commit real credentials
.env

# auto-screener recommendation outputs (regenerated)
cache_seed/discovered_screens/

# trained ML models + agents (regenerated by ml_supervised / rl_trader)
cache_seed/models/

# CRUD pipeline registry (regenerated by pipeline.py --sync)
cache_seed/pipeline_state.json

# STM seeds are derived from the committed LTM (market_memory.ensure_stm_seeds)
# — not committed, to avoid ~120MB duplication (STM is a trailing 1y slice of LTM)
cache_seed/cleaned_long.parquet
cache_seed/cleaned_long_*.parquet
KARZ_DEPLOYMENT_FINAL_SUMMARY.md
# Legacy monolithic panels — superseded 2026-07-22 by warehouse/ (year-partitioned).
# Files remain locally as caches; the warehouse is the tracked store.
cache_seed/ltm/US.parquet
cache_seed/ltm/JP.parquet
cache_seed/ltm/KR.parquet
cache_seed/ltm/CN.parquet
cache_seed/ltm/IN.parquet
*.bak
warehouse/etl_registry.sqlite
